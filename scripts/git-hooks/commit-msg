#!/bin/sh
# Local commit-msg hook. Installed via `make hooks`. Reads the proposed
# message from the file git passes as $1, extracts the subject (first
# non-comment line), and runs scripts/check-commit-msg.sh on it.

root=$(git rev-parse --show-toplevel)
subject=$(sed -E '/^#/d;/^$/d' "$1" | head -n 1)

if ! "$root/scripts/check-commit-msg.sh" "$subject"; then
  echo "" >&2
  echo "  rule: ^[A-Za-z0-9 ,]{4,72}\$" >&2
  echo "  see: CONTRIBUTING.md" >&2
  exit 1
fi
