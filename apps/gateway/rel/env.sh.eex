#!/bin/sh
# Per-region node name. On Railway, each replica gets `RAILWAY_PRIVATE_IP`
# (an IPv6 address routed on the project's private network); on Fly it's
# `FLY_PRIVATE_IP`. We pick whichever is set. Fallback to 127.0.0.1 for
# single-node local runs.
export ERL_AFLAGS="-proto_dist inet6_tcp"
export RELEASE_DISTRIBUTION=name
export RELEASE_NODE="hela-${HELA_REGION:-dev}@${RAILWAY_PRIVATE_IP:-${FLY_PRIVATE_IP:-127.0.0.1}}"
