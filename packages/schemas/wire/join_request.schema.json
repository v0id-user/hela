{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hela.dev/schemas/wire/join_request.schema.json",
  "title": "JoinRequest",
  "description": "Payload for `phx_join` on a `chan:<project>:<channel>` topic.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nickname": {
      "type": "string",
      "maxLength": 64,
      "description": "Display name used for presence roster + default author on publishes."
    }
  }
}
