{
  "name": "hela",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/web",
    "apps/app",
    "apps/docs",
    "packages/config",
    "packages/sdk-js",
    "packages/sdk-js-e2e",
    "packages/sdk-types",
    "packages/ui"
  ],
  "scripts": {
    "dev": "make dev",
    "build": "bun run --filter=* build",
    "build:sdk": "cd packages/sdk-types && bun run build && cd ../sdk-js && bun run build",
    "test:e2e": "cd packages/sdk-js-e2e && bun run test",
    "test:e2e:headed": "cd packages/sdk-js-e2e && bun run test:headed",
    "dev:web": "bun run build:sdk && bun run dev:web:raw",
    "dev:app": "bun run build:sdk && bun run dev:app:raw",
    "dev:web:raw": "cd apps/web && bun run dev",
    "dev:app:raw": "cd apps/app && bun run dev",
    "dev:all": "bun run build:sdk && concurrently -n g,c,w,a -c auto \"make dev.gateway\" \"make dev.control\" \"bun run dev:web:raw\" \"bun run dev:app:raw\"",
    "lint": "eslint --max-warnings 0 ."
  },
  "packageManager": "bun@1.1.34",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  }
}
